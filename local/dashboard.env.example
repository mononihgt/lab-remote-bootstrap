# Local machine only: used by local/open_clash_dashboard.sh

CLOUD_HOST=your_cloud_host
REVERSE_PORT=2222

# SSH user on the target host reachable via reverse tunnel
DASHBOARD_SSH_USER=your_host_user

# Optional SSH private key file for publickey-only login
# Example: ~/.ssh/id_ed25519
# DASHBOARD_SSH_IDENTITY_FILE=~/.ssh/id_ed25519

# Clash external-controller port on target host
CLASH_API_PORT=9090

# Local forwarded port
LOCAL_DASHBOARD_PORT=9090

# Optional dashboard UI URL
DASHBOARD_URL=https://metacubex.github.io/metacubexd/
